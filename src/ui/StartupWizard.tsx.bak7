import React, { useState, useEffect } from 'react';
import { Box, Text, useInput } from 'ink';
import { ThemeMode, getThemeLabel, setThemeMode, getColors } from './theme.js';
import type { LLMProvider } from '../llm/client.js';

type Step = 'welcome' | 'theme' | 'backend' | 'done';

type Props = {
  onDone: (theme: ThemeMode, backend: LLMProvider) => void;
};

const THEME_OPTIONS: { value: ThemeMode; label: string; hint: string }[] = [
  { value: 'light', label: 'Light',        hint: 'Clean and bright' },
  { value: 'dark',  label: 'Dark',         hint: 'Easy on the eyes' },
  { value: 'auto',  label: 'Auto В· Adaptive', hint: 'Shifts with the time of day' },
];

const BACKEND_OPTIONS: { value: LLMProvider; label: string; hint: string }[] = [
  { value: 'gemini', label: 'Gemini',  hint: 'Google В· Fast В· Free tier' },
  { value: 'groq',   label: 'Groq',    hint: 'Ultra-fast inference В· Free tier' },
  { value: 'ollama', label: 'Ollama',  hint: 'Local В· Unlimited В· qwen2.5-coder' },
];

// ASCII лЎңкі 
const LOGO = [
  '   в–„в–Ҳв–Ҳв–Ҳв–Ҳв–„   в–Ҳв–Ҳв–“    в–„в–„в–„       в–Ҳ    в–Ҳв–Ҳ в–“в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–„ в–“в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳ ',
  '  в–’в–Ҳв–Ҳв–Җ в–Җв–Ҳ  в–“в–Ҳв–Ҳв–’   в–’в–Ҳв–Ҳв–Ҳв–Ҳв–„     в–Ҳв–Ҳ  в–“в–Ҳв–Ҳв–’в–’в–Ҳв–Ҳв–Җ в–Ҳв–Ҳв–Ңв–“в–Ҳ   в–Җ ',
  '  в–’в–“в–Ҳ    в–„ в–’в–Ҳв–Ҳв–‘   в–’в–Ҳв–Ҳ  в–Җв–Ҳв–„  в–“в–Ҳв–Ҳ  в–’в–Ҳв–Ҳв–‘в–‘в–Ҳв–Ҳ   в–Ҳв–Ңв–’в–Ҳв–Ҳв–Ҳ   ',
  '  в–’в–“в–“в–„ в–„в–Ҳв–Ҳв–’в–’в–Ҳв–Ҳв–‘   в–‘в–Ҳв–Ҳв–„в–„в–„в–„в–Ҳв–Ҳ в–“в–“в–Ҳ  в–‘в–Ҳв–Ҳв–‘в–‘в–“в–Ҳв–„   в–Ңв–’в–“в–Ҳ  в–„ ',
  '  в–’ в–“в–Ҳв–Ҳв–Ҳв–Җ в–‘в–‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–’в–“в–Ҳ   в–“в–Ҳв–Ҳв–’в–’в–’в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–“ в–‘в–’в–Ҳв–Ҳв–Ҳв–Ҳв–“ в–‘в–’в–Ҳв–Ҳв–Ҳв–Ҳв–’',
];

export function StartupWizard({ onDone }: Props) {
  const [step, setStep] = useState<Step>('welcome');
  const [themeIdx, setThemeIdx] = useState(2);
  const [backendIdx, setBackendIdx] = useState(0);
  const [pickedTheme, setPickedTheme] = useState<ThemeMode>('auto');
  const [logoFrame, setLogoFrame] = useState(0);

  // нҷҳмҳҒ нҷ”л©ҙ мһҗлҸҷ м§„н–ү + лЎңкі  нҺҳмқҙл“ңмқё
  useEffect(() => {
    if (step !== 'welcome') return;
    const fade = setInterval(() => {
      setLogoFrame((f) => Math.min(f + 1, LOGO.length));
    }, 80);
    const advance = setTimeout(() => setStep('theme'), 1400);
    return () => {
      clearInterval(fade);
      clearTimeout(advance);
    };
  }, [step]);

  // н…Ңл§Ҳ лҜёлҰ¬ліҙкё°
  const previewTheme =
    step === 'theme' ? THEME_OPTIONS[themeIdx].value : pickedTheme;
  setThemeMode(previewTheme);
  const colors = getColors();

  useInput((input, key) => {
    if (step === 'welcome') {
      if (key.return || input) setStep('theme');
      return;
    }
    if (step === 'theme') {
      if (key.upArrow)
        setThemeIdx((i) => (i - 1 + THEME_OPTIONS.length) % THEME_OPTIONS.length);
      else if (key.downArrow)
        setThemeIdx((i) => (i + 1) % THEME_OPTIONS.length);
      else if (key.return) {
        const chosen = THEME_OPTIONS[themeIdx].value;
        setPickedTheme(chosen);
        setThemeMode(chosen);
        setStep('backend');
      }
    } else if (step === 'backend') {
      if (key.upArrow)
        setBackendIdx(
          (i) => (i - 1 + BACKEND_OPTIONS.length) % BACKEND_OPTIONS.length,
        );
      else if (key.downArrow)
        setBackendIdx((i) => (i + 1) % BACKEND_OPTIONS.length);
      else if (key.return) {
        onDone(pickedTheme, BACKEND_OPTIONS[backendIdx].value);
      } else if (key.escape) {
        setStep('theme');
      }
    }
  });

  // в”Җв”Җ нҷҳмҳҒ нҷ”л©ҙ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  if (step === 'welcome') {
    return (
      <Box flexDirection="column" alignItems="center" paddingY={2}>
        <Box flexDirection="column">
          {LOGO.slice(0, logoFrame).map((line, i) => (
            <Text key={i} color={colors.signature} bold>
              {line}
            </Text>
          ))}
        </Box>
        {logoFrame >= LOGO.length && (
          <Box flexDirection="column" alignItems="center" marginTop={1}>
            <Text color={colors.accent} bold>
              в”Җв”Җв”Җв”Җв”Җ  Your local coding companion  в”Җв”Җв”Җв”Җв”Җ
            </Text>
            <Box marginTop={1}>
              <Text color={colors.dim}>Press </Text>
              <Text color={colors.accent} bold>Enter</Text>
              <Text color={colors.dim}> to begin</Text>
            </Box>
          </Box>
        )}
      </Box>
    );
  }

  // в”Җв”Җ л©”мқё мң„м Җл“ң (н…Ңл§Ҳ/л°ұм—”л“ң) в”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  const stepNum = step === 'theme' ? 1 : 2;
  const stepTitle =
    step === 'theme' ? 'Choose your theme' : 'Choose your engine';
  const stepHint =
    step === 'theme'
      ? 'вҶ‘/вҶ“ navigate   вҸҺ select'
      : 'вҶ‘/вҶ“ navigate   вҸҺ select   esc back';

  const options = step === 'theme' ? THEME_OPTIONS : BACKEND_OPTIONS;
  const activeIdx = step === 'theme' ? themeIdx : backendIdx;

  return (
    <Box
      flexDirection="column"
      borderStyle="round"
      borderColor={colors.signature}
      paddingX={3}
      paddingY={1}
    >
      {/* н—ӨлҚ” */}
      <Box justifyContent="space-between" marginBottom={1}>
        <Text color={colors.signature} bold>
          вңҰ Welcome to Claude
        </Text>
        <Text color={colors.dim}>{stepNum} / 2</Text>
      </Box>

      {/* кө¬л¶„м„  */}
      <Text color={colors.dim}>
        в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
      </Text>

      {/* нғҖмқҙнӢҖ */}
      <Box marginTop={1} marginBottom={1}>
        <Text color={colors.text} bold>
          {stepTitle}
        </Text>
      </Box>

      {/* мҳөм…ҳ лҰ¬мҠӨнҠё */}
      <Box flexDirection="column">
        {options.map((opt, i) => {
          const active = i === activeIdx;
          return (
            <Box key={opt.value} marginY={0}>
              <Text color={active ? colors.signature : colors.dim}>
                {active ? 'в–ё ' : '  '}
              </Text>
              <Box width={22}>
                <Text
                  color={active ? colors.accent : colors.text}
                  bold={active}
                >
                  {opt.label}
                </Text>
              </Box>
              <Text color={active ? colors.text : colors.dim}>
                {opt.hint}
              </Text>
            </Box>
          );
        })}
      </Box>

      {/* н‘ён„° */}
      <Box marginTop={1}>
        <Text color={colors.dim}>
          в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        </Text>
      </Box>

      <Box justifyContent="space-between" marginTop={1}>
        <Text color={colors.dim}>{stepHint}</Text>
        {step === 'backend' && (
          <Box>
            <Text color={colors.dim}>theme: </Text>
            <Text color={colors.accent}>{getThemeLabel(pickedTheme)}</Text>
          </Box>
        )}
      </Box>
    </Box>
  );
}
