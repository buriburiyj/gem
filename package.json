{
  "name": "gem",
  "version": "0.0.1",
  "description": "Claude Code clone powered by Gemini (with Groq fallback)",
  "type": "module",
  "bin": {
    "claude": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "snake": "tsx src/snake/cli.tsx",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "cli",
    "ai",
    "coding",
    "gemini",
    "claude-code"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/groq": "^3.0.42",
    "ai": "^6.0.208",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
